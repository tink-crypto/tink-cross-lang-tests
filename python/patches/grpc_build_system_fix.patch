# This patch removes src/core/ext/upb-gen and src/core/ext/upbdefs-gen from the includes list in grpc_cc_library.
# This prevents Bazel from finding pre-generated upb headers in the source tree, which causes undeclared inclusion errors because they are not declared as dependencies (they are expected to be generated by @com_google_protobuf).
--- a/bazel/grpc_build_system.bzl
+++ b/bazel/grpc_build_system.bzl
@@ -189,5 +189,3 @@
         includes = [
             include_prefix + "include",
-            include_prefix + "src/core/ext/upb-gen",  # Once upb code-gen issue is resolved, remove this.
-            include_prefix + "src/core/ext/upbdefs-gen",  # Once upb code-gen issue is resolved, remove this.
         ],
